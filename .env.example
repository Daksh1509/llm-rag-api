# LLM Provider - choose one
OPENAI_API_KEY=your_openai_key_here

# App Config
APP_NAME=LLM-RAG-API
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO

# RAG Config
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=5
SIMILARITY_THRESHOLD=0.30

# LLM Config
LLM_MODEL=gpt-3.5-turbo
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.2

# Cache
CACHE_TTL_SECONDS=300